		"scope": "javascriptreact,javascript,typescriptreact,typescript",
		"prefix": "try-catch-finally",
		"body": [
			"try {",
			"\t$1",
			"} catch (e) {",
			"\t$2",
			"}",
			"} finally {",
			"\t$3",
			"}",
		]
	},
	"File Name": {
		"prefix": "filename",
		"body": "${1:${TM_FILENAME_BASE}}"
	}
