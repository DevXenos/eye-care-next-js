	"Provider Template": {
		"scope": "javascriptreact,typescriptreact",
		"prefix": "context-provider",
		"body": [
			"import { LayoutProp } from '@/types/LayoutProp';",
			"import { createContext, useContext } from 'react';",
			"",
			"type $1ContextType = {",
			"\t$2",
			"}",
			"",
			"const $1Context = createContext<$1ContextType|undefined>(undefined);",
			"",
			"export function $1Provider({children}: LayoutProp) {",
			"\t$3",
			"\t",
			"\treturn (",
			"\t\t<$1Context.Provider value={{$4}}>",
			"\t\t\t{children}",
			"\t\t</$1Context.Provider>",
			"\t)",
			"\t",
			"}",
			"",
			"export default function use$1() {",
			"\tconst context = useContext($1Context);",
			"\tif(!context) throw new Error(\"'use$1' must be used inside of '$1Provider'\")",
			"\treturn context;",
			"}",
		]
	},
	"Try And Catch": {
		"scope": "javascriptreact,javascript,typescriptreact,typescript",
		"prefix": "try-catch",
		"body": [
